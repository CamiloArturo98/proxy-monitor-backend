# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=8080

# CORS: URL de producción del frontend en Vercel
# Separar múltiples orígenes con coma
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://tu-app.vercel.app

# Tasa de fallos simulados para PaymentService (0.0 - 1.0)
APP_PROXY_PAYMENT_FAILURE_RATE=0.10

# Número de llamadas para la simulación de carga
APP_PROXY_SIMULATE_LOAD_CALLS=50